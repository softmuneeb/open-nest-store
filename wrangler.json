{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "open-nest-store",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat", "no_handle_cross_request_promise_resolution"],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"vars": {
		"MONGODB_DB": "opennest"
	}
}
